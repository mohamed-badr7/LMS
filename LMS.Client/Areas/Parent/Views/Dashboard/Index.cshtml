@{
    ViewData["Title"] = "Parent Dashboard";
    ViewBag.CardTitle = "Welcome to Your Dashboard";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-person me-2"></i>Profile</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <a asp-controller="Profile" asp-action="Index" class="text-decoration-none d-flex align-items-center">
                                <i class="bi bi-person me-2"></i> My Profile
                            </a>
                        </li>
                        <li class="mb-2">
                            <a asp-controller="Profile" asp-action="ReceivedNotifications" class="text-decoration-none d-flex align-items-center">
                                <i class="bi bi-bell me-2"></i> Notifications
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Academics</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <a asp-controller="Student" asp-action="Assignments" class="text-decoration-none d-flex align-items-center">
                                <i class="bi bi-clipboard-data me-2"></i> Children Assignments
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Student" asp-action="Grades" class="text-decoration-none d-flex align-items-center">
                                <i class="bi bi-calendar-check me-2"></i> Children Grades
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Student" asp-action="ExamResults" class="text-decoration-none d-flex align-items-center">
                                <i class="bi bi-list-task me-2"></i> Exam Results
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Student" asp-action="Schedule" class="text-decoration-none d-flex align-items-center">
                                <i class="bi bi-card-checklist me-2"></i> Schedule
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-folder me-2"></i>Finance</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li>
                            <a asp-controller="Finance" asp-action="Fees" class="text-decoration-none d-flex align-items-center">
                                <i class="bi bi-file-earmark-text me-2"></i> Fees
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s ease-in-out;
    }

        .card:hover {
            transform: translateY(-3px);
        }

    a:hover {
        color: var(--bs-primary) !important;
    }

    .card-header {
        border-bottom: none;
    }
</style>

